# rosclaw-mujoco — environment variables
# Copy this file to `.env` and fill in real values.
# `.env` is gitignored; `.env.example` is the canonical list.

# ── Required ──
# Google AI Studio API key for the Gemini NLP ROS2 node.
# Get one at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=__REPLACE_ME__

# ── Optional ──
# rosbridge WebSocket URL — defaults to ws://127.0.0.1:9090 in both
# mujoco_sim/segway_bridge.py and extensions/openclaw-plugin.
# Override only when running against a remote rosbridge.
# ROSBRIDGE_URL=ws://127.0.0.1:9090

# ROS2 domain ID used by all Docker services. Keep the same value across
# every consumer or topics will not be visible. Defaults to 0.
# ROS_DOMAIN_ID=0
